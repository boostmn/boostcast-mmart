# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored (contains secrets).
project_id        = "your-gcp-project"
region            = "asia-east2"
zone              = "asia-east2-a"
machine_type      = "e2-medium"
disk_size_gb      = 50

# No domain: leave these empty to access over HTTP at http://<public-ip>.
# (Set a domain + email later to enable automatic Let's Encrypt HTTPS.)
domain            = ""
letsencrypt_email = ""

# Required: database password (set before first boot).
mysql_password    = "change-me-to-a-strong-password"
